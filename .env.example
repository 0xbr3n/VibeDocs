# Copy to .env and edit. Never commit .env to git.

# === Database ===
POSTGRES_USER=vapt
POSTGRES_PASSWORD=change_this_to_a_strong_password
POSTGRES_DB=vapt_reporter

# === App ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace_with_a_64_byte_random_string

# Session length in minutes (default 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Bind ports on the host
APP_PORT=8000
NGINX_PORT=80

# Comma separated list, * for any (only safe behind internal network)
ALLOWED_HOSTS=*

# === IP / VPN whitelist (optional) ===
# Comma-separated list of IPs and/or CIDR ranges allowed to reach the app.
# Empty (the default) disables the check — anyone who can hit nginx can
# reach the API. Set this to your corporate VPN ranges to lock the app
# down to trusted networks.
#
# Examples:
#   ALLOWED_IPS=10.0.0.0/8, 192.168.0.0/16        # internal RFC1918
#   ALLOWED_IPS=203.0.113.42, 198.51.100.0/24     # explicit VPN egress IPs
#
# Paths that should ALWAYS be reachable regardless of source IP (the
# docker healthcheck, the static asset folder, etc.):
#   ALLOWED_IPS_BYPASS_PATHS=/health,/static
#
# Set ALLOWED_IPS_LOG_ONLY=1 during rollout — the middleware will LOG
# rejected IPs but still let them through, so you can confirm the rules
# are right before flipping the gate on.
ALLOWED_IPS=
ALLOWED_IPS_BYPASS_PATHS=/health,/static
ALLOWED_IPS_LOG_ONLY=

# production or development
ENV=production

# === Authentication ===
# 'local'  : username + password against the User table (default; ships working)
# 'oidc'   : OpenID Connect for VibeDocs SSO (scaffold; uncomment OIDC_* below)
AUTH_PROVIDER=local

# OIDC config (uncomment + fill when ready to switch to VibeDocs SSO).
# Local accounts continue to work as a break-glass fallback at /api/auth/local/login.
#OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_REDIRECT_URI=https://vapt.internal/api/auth/oidc/callback
#OIDC_SCOPES=openid email profile
#OIDC_USERNAME_CLAIM=preferred_username

# === Outbound email (password reset, project-deletion notices) ===
# Leave SMTP_HOST blank to disable real sending — outgoing messages are then
# written to ${DATA_DIR}/outgoing-mail/<timestamp>.eml so developers can read
# the reset link without configuring a relay.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraccount@gmail.com
#   SMTP_PASS=<an app password — NOT your real Gmail password>
#   SMTP_FROM=youraccount@gmail.com
#
# Microsoft 365 / Outlook example:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USER=you@yourdomain.com
#   SMTP_PASS=<account password or app password>
#   SMTP_FROM=you@yourdomain.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=vapt-reporter@localhost

# Where DATA_DIR points (kept in sync with docker-compose volumes).
DATA_DIR=/data
